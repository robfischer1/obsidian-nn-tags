{
	"name": "obsidian-notebook-tags-plugin",
	"version": "1.2.0",
	"description": "Render Notebook Navigator tag icons, labels, and colors inline for markdown tags and tag pills.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run --passWithNoTests"
	},
	"author": "Rob Fischer",
	"repository": {
		"type": "git",
		"url": "https://github.com/robfischer1/obsidian-nn-tags"
	},
	"homepage": "https://github.com/robfischer1/obsidian-nn-tags#readme",
	"keywords": ["obsidian", "obsidian-plugin", "notebook-navigator", "tags"],
	"license": "Apache-2.0",
	"devDependencies": {
		"@codemirror/language": "^6.8.0",
		"@codemirror/state": "^6.2.1",
		"@codemirror/view": "^6.15.3",
		"@eslint/js": "9.30.1",
		"@types/node": "^22.0.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.7.0",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.7"
	}
}
